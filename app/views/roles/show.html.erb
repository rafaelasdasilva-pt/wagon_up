<% @role ||= OpenStruct.new(
  title: "Junior Web Developer",
  justification: "Your combination of full-stack skills and previous career experience makes you a strong candidate for web development roles.",
  position: 1,
  market_fit: {}
) %>

<div style="background:var(--bg);padding:3rem 1rem;min-height:calc(100vh - 68px)">
  <div style="max-width:760px;margin:0 auto">

    <%# Back link %>
    <%# TODO: substituir analyses_path por profile_path quando existir %>
    <%= link_to "← Back to profile", analyses_path,
        style: "font-size:.83rem;color:var(--ink-3);text-decoration:none;display:inline-flex;align-items:center;gap:.4rem;margin-bottom:1.5rem" %>

    <%# Title block %>
    <div class="sr">
      <span style="font-size:.75rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--brand)">
        Career path
      </span>
      <h1 style="font-size:2.2rem;font-weight:800;letter-spacing:-.03em;color:var(--ink);margin-top:.5rem;margin-bottom:.75rem">
        <%= @role.title %>
      </h1>
      <p style="font-size:1rem;color:var(--ink-3);line-height:1.75;margin-bottom:2rem">
        <%= @role.justification %>
      </p>
    </div>

    <%# Market fit progress %>
    <div class="wu-card mb-4 sr d1">
      <div style="font-size:.78rem;font-weight:700;color:var(--ink-3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:1rem">
        Market Fit
      </div>
      <% match_pct = @role.position == 1 ? 87 : @role.position == 2 ? 82 : 79 %>
      <div class="wu-progress mb-2">
        <div class="wu-progress-fill" data-width="<%= match_pct %>%" style="width:0%"></div>
      </div>
      <div style="font-size:.83rem;color:var(--ink-3)">
        <%= match_pct %>% compatibility with your profile
      </div>
    </div>

    <%# Market Data tabs %>
    <% if @role.market_fit.present? && @role.market_fit.is_a?(Hash) %>
      <% country_flags = {
           "Brazil" => "🇧🇷", "Portugal" => "🇵🇹", "Internacional" => "🌍",
           "United States" => "🇺🇸", "France" => "🇫🇷", "Germany" => "🇩🇪",
           "Spain" => "🇪🇸", "United Kingdom" => "🇬🇧", "Canada" => "🇨🇦",
           "Australia" => "🇦🇺", "Netherlands" => "🇳🇱", "Switzerland" => "🇨🇭",
           "Ireland" => "🇮🇪", "Sweden" => "🇸🇪", "Denmark" => "🇩🇰",
           "Norway" => "🇳🇴", "Finland" => "🇫🇮", "Belgium" => "🇧🇪",
           "Austria" => "🇦🇹", "Italy" => "🇮🇹", "Poland" => "🇵🇱",
           "Singapore" => "🇸🇬", "Japan" => "🇯🇵", "New Zealand" => "🇳🇿",
           "UAE" => "🇦🇪", "Mexico" => "🇲🇽", "Argentina" => "🇦🇷",
           "Chile" => "🇨🇱", "Colombia" => "🇨🇴", "Luxembourg" => "🇱🇺",
           "Israel" => "🇮🇱", "South Korea" => "🇰🇷", "South Africa" => "🇿🇦",
           "Estonia" => "🇪🇪", "Malta" => "🇲🇹", "Greece" => "🇬🇷",
           "Turkey" => "🇹🇷", "Indonesia" => "🇮🇩", "India" => "🇮🇳",
           "China" => "🇨🇳", "Hong Kong" => "🇭🇰"
         } %>
      <% markets = @role.market_fit.map { |country, data|
           [country, country_flags[country] || "🌍", data]
         }.select { |_, _, data| data.present? } %>

      <% if markets.any? %>
        <div class="wu-card mb-4 sr d2" data-controller="market-tabs">
          <div style="font-size:.78rem;font-weight:700;color:var(--brand);text-transform:uppercase;letter-spacing:.1em;margin-bottom:1.25rem">
            Market Data
          </div>

          <%# Tabs %>
          <div style="display:flex;gap:0;border-bottom:2px solid var(--border);margin-bottom:1.5rem">
            <% markets.each_with_index do |(label, flag, _), i| %>
              <button
                data-market-tabs-target="tab"
                data-action="click->market-tabs#select"
                style="background:none;border:none;border-bottom:2px solid transparent;margin-bottom:-2px;padding:.5rem 1.25rem .6rem;font-size:.88rem;cursor:pointer;transition:color .2s,border-color .2s">
                <%= flag %> <%= label %>
              </button>
            <% end %>
          </div>

          <%# Panels %>
          <% markets.each_with_index do |(label, _flag, data), i| %>
            <div data-market-tabs-target="panel" hidden>
              <%# Metric cards row %>
              <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:.6rem;margin-bottom:1rem">

                <%# Salary %>
                <div style="background:#fff;border:1px solid var(--border);border-radius:12px;padding:.85rem .75rem;text-align:center">
                  <div style="font-size:.92rem;font-weight:700;color:var(--ink);line-height:1.35"><%= data["salario"] %></div>
                  <div style="font-size:.6rem;font-weight:600;color:var(--ink-3);text-transform:uppercase;letter-spacing:.09em;margin-top:.4rem"><%= data["periodo"] || "per month" %></div>
                </div>

                <%# Market demand %>
                <div style="background:#fff;border:1px solid var(--border);border-radius:12px;padding:.85rem .75rem;text-align:center">
                  <div style="font-size:.92rem;font-weight:700;color:var(--ink)"><%= data["demanda"] %></div>
                  <% pct = data["percentual_demanda"].to_i %>
                  <div style="height:3px;background:var(--border);border-radius:2px;margin:.45rem 0">
                    <div style="height:3px;background:var(--brand);border-radius:2px;width:<%= pct %>%"></div>
                  </div>
                  <div style="font-size:.6rem;font-weight:600;color:var(--ink-3);text-transform:uppercase;letter-spacing:.09em">Market Demand</div>
                </div>

                <%# Trend %>
                <div style="background:#fff;border:1px solid var(--border);border-radius:12px;padding:.85rem .75rem;text-align:center">
                  <div style="font-size:.92rem;font-weight:700;color:var(--ink)"><%= data["tendencia"] %></div>
                  <div style="font-size:.6rem;font-weight:600;color:var(--ink-3);text-transform:uppercase;letter-spacing:.09em;margin-top:.4rem">2025 Trend</div>
                </div>

                <%# Time to hire %>
                <div style="background:#fff;border:1px solid var(--border);border-radius:12px;padding:.85rem .75rem;text-align:center">
                  <div style="font-size:.92rem;font-weight:700;color:var(--ink)"><%= data["tempo_contratacao"] %></div>
                  <div style="font-size:.6rem;font-weight:600;color:var(--ink-3);text-transform:uppercase;letter-spacing:.09em;margin-top:.4rem">Avg. Time to Hire</div>
                </div>

              </div>

              <%# Insight %>
              <% if data["insight"].present? %>
                <div style="background:var(--brand-pale);border-radius:10px;padding:1rem 1.25rem">
                  <p style="font-size:.87rem;color:var(--ink-2);line-height:1.75;margin:0"><%= data["insight"].html_safe %></p>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <%# Why this fits %>
    <div class="sr d3" style="margin-bottom:1.5rem">
      <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.25rem">
        <span style="font-size:.72rem;font-weight:700;color:var(--brand);text-transform:uppercase;letter-spacing:.12em;white-space:nowrap">Why this fits you</span>
        <div style="flex:1;height:1px;background:var(--border)"></div>
      </div>

      <div class="wu-card">
        <p style="font-size:.97rem;color:var(--ink-2);line-height:1.8;margin-bottom:1.5rem">
          <%= @role.justification %>
        </p>

        <% breakdown = @analysis&.raw_json&.dig("cargos_sugeridos", @role.position - 1, "breakdown") %>
        <% if breakdown.present? %>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem">
            <% breakdown.each do |item| %>
              <div style="border:1px solid var(--border);border-radius:14px;padding:1.1rem 1.25rem">
                <div style="display:flex;align-items:center;gap:.65rem;margin-bottom:.6rem">
                  <span style="font-size:1.25rem;background:var(--brand-pale);border-radius:10px;padding:.35rem .4rem;line-height:1;flex-shrink:0"><%= item["icone"] %></span>
                  <span style="font-size:.82rem;color:var(--ink-3);line-height:1.4"><%= item["passado"] %></span>
                </div>
                <div style="font-size:.85rem;color:var(--brand);margin-bottom:.4rem">↓</div>
                <div style="font-size:.97rem;font-weight:700;color:var(--ink)"><%= item["futuro"] %></div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# Gap Analysis %>
    <% lacunas = @analysis&.raw_json&.dig("cargos_sugeridos", @role.position - 1, "analise_lacunas") %>
    <% if lacunas.present? %>
      <div class="sr d4" style="margin-bottom:1.5rem">
        <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.25rem">
          <span style="font-size:.72rem;font-weight:700;color:var(--brand);text-transform:uppercase;letter-spacing:.12em;white-space:nowrap">Gap Analysis</span>
          <div style="flex:1;height:1px;background:var(--border)"></div>
        </div>

        <div class="wu-card">
          <p style="font-size:.93rem;color:var(--ink-2);line-height:1.8;margin-bottom:1.25rem">
            Honest overview of where you stand — and what could make your profile even stronger.
          </p>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem">

            <%# What you have %>
            <div style="border:1.5px solid #86efac;border-radius:14px;padding:1.25rem;background:#f0fdf4">
              <div style="font-size:.72rem;font-weight:700;color:#16a34a;text-transform:uppercase;letter-spacing:.1em;margin-bottom:1rem">
                ✅ What you have
              </div>
              <% (lacunas["tenho"] || []).each do |skill| %>
                <div style="display:flex;align-items:flex-start;gap:.6rem;margin-bottom:.6rem">
                  <span style="color:#16a34a;font-size:.85rem;flex-shrink:0;margin-top:.05rem">✓</span>
                  <span style="font-size:.87rem;color:var(--ink-2)"><%= skill %></span>
                </div>
              <% end %>
            </div>

            <%# Would strengthen you %>
            <div style="border:1.5px solid #fde68a;border-radius:14px;padding:1.25rem;background:#fffbeb">
              <div style="font-size:.72rem;font-weight:700;color:#b45309;text-transform:uppercase;letter-spacing:.1em;margin-bottom:1rem">
                🔶 Would strengthen you
              </div>
              <% (lacunas["falta"] || []).each do |item| %>
                <div style="margin-bottom:1rem">
                  <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.4rem">
                    <span style="color:#b45309;font-weight:700;font-size:.9rem">+</span>
                    <span style="font-size:.9rem;font-weight:700;color:var(--ink)"><%= item["habilidade"] %></span>
                  </div>
                  <div style="display:flex;align-items:flex-start;gap:.5rem;padding-left:.1rem">
                    <span style="color:var(--ink-3);font-size:.85rem;flex-shrink:0">🔗</span>
                    <span style="font-size:.82rem;color:var(--ink-3);line-height:1.5"><%= item["recurso"] %></span>
                  </div>
                </div>
              <% end %>
            </div>

          </div>
        </div>
      </div>
    <% end %>

    <%# AI CV Generator %>
    <div class="sr d4" style="margin-bottom:1.5rem">
      <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.25rem">
        <span style="font-size:.72rem;font-weight:700;color:var(--brand);text-transform:uppercase;letter-spacing:.12em;white-space:nowrap">AI CV Generator</span>
        <div style="flex:1;height:1px;background:var(--border)"></div>
      </div>

      <div class="wu-prompt-box">
        <div style="font-size:1.05rem;font-weight:700;color:var(--ink);margin-bottom:.3rem">Your tailored CV, ready to download</div>
        <p style="font-size:.87rem;color:var(--ink-3);margin-bottom:1.25rem">
          We read your CV and generates a new, optimised version tailored specifically for
          <strong><%= @role.title %></strong> highlighting your transferable skills and bootcamp projects.
          Download it as a PDF
        </p>

        <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
          <a href="<%= cv_role_path(@role) %>"
             id="cv-download-btn"
             data-turbo="false"
             onclick="
               var btn = document.getElementById('cv-download-btn');
               btn.style.opacity = '0.7';
               btn.style.pointerEvents = 'none';
               btn.innerHTML = '<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'16\' height=\'16\' fill=\'currentColor\' viewBox=\'0 0 16 16\' style=\'animation:spin 1s linear infinite;flex-shrink:0\'><path d=\'M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z\'/><path d=\'M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z\'/></svg> Generating your CV...';
               setTimeout(function(){ btn.style.opacity='1'; btn.style.pointerEvents='auto'; btn.innerHTML='<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'16\' height=\'16\' fill=\'currentColor\' viewBox=\'0 0 16 16\' style=\'flex-shrink:0\'><path d=\'M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5\'/><path d=\'M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z\'/></svg> Generate &amp; Download CV'; }, 40000);"
             style="display:inline-flex;align-items:center;gap:.6rem;background:var(--brand);color:#fff;border:none;border-radius:10px;padding:.75rem 1.5rem;font-size:.95rem;font-weight:700;cursor:pointer;text-decoration:none;transition:opacity .2s">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="flex-shrink:0">
              <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
              <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/>
            </svg>
            Generate &amp; Download CV
          </a>

          <span style="font-size:.8rem;color:var(--ink-3)">
            PDF · Tailored for <%= @role.title %> · ATS-optimised
          </span>
        </div>
        <style>@keyframes spin { from { transform: rotate(0deg) } to { transform: rotate(360deg) } }</style>
      </div>
    </div>

    <%# Start interview CTA %>
    <div class="wu-card mb-4 sr d3" style="text-align:center;padding:2rem">
      <div style="font-size:1.5rem;margin-bottom:.75rem">💬</div>
      <h5 class="fw-800 mb-2">Ready to practice?</h5>
      <p style="font-size:.88rem;color:var(--ink-3);margin-bottom:1.25rem">
        Start a mock interview, tailored for <%= @role.title %> roles.
      </p>
      <%# TODO: substituir "#" por new_role_interview_path(@role) %>
      <%= link_to "Start interview →", "#", class: "btn-wu btn-wu-primary" %>
    </div>

    <%# Back link bottom %>
    <%# TODO: substituir analyses_path por profile_path quando existir %>
    <%= link_to "← Back to profile", analyses_path,
        style: "font-size:.83rem;color:var(--ink-3);text-decoration:none;display:inline-flex;align-items:center;gap:.4rem" %>

  </div>
</div>
