<%# ── Hero ──────────────────────────────────────────────────────────────────── %>
<div class="wu-hero">
  <div class="wu-hero-badge sr">
    <span class="dot"></span>
    TRUSTED BY 2,400+ CAREER SEEKERS
  </div>

  <h1 class="wu-hero-h1 sr d1">
    You don't need more skills.<br>
    <span class="accent">You need the right positioning.</span>
  </h1>

  <div class="sr d2" style="position:relative;z-index:1">
    <% if user_signed_in? %>
      <%= link_to "Go to my profile →", analyses_path, class: "btn-wu btn-wu-primary btn-wu-lg" %>
    <% else %>
      <%= link_to "Sign up here", new_user_registration_path, class: "btn-wu btn-wu-primary btn-wu-lg" %>
    <% end %>
    <p class="wu-hero-note sr d3">For Le Wagon graduates ready to land their first tech job</p>
  </div>
</div>

<%# ── Stats band ───────────────────────────────────────────────────────────── %>
<div class="wu-stats-band">
  <div class="wu-stat-cell">
    <span class="wu-stat-n">87%</span>
    <span class="wu-stat-l">Interview success rate</span>
  </div>
  <div class="wu-stat-cell">
    <span class="wu-stat-n">2,400+</span>
    <span class="wu-stat-l">Careers repositioned</span>
  </div>
  <div class="wu-stat-cell">
    <span class="wu-stat-n">4.9/5</span>
    <span class="wu-stat-l">Average user rating</span>
  </div>
</div>

<%# ── Wave divider ──────────────────────────────────────────────────────────── %>
<div class="wu-wave-divider">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,0 C360,60 1080,60 1440,0 L1440,60 L0,60 Z" fill="#f5f3ff"/>
  </svg>
</div>

<section class="py-9" id="how-it-works" style="background:#f5f3ff">
  <div class="container" style="max-width:1100px">
    <div class="text-center mb-5">
      <h2 class="fw-800 fs-2">How it works</h2>
      <p style="color:var(--ink-3);max-width:480px;margin:0 auto;line-height:1.7">
        Four steps from upload to offer. The whole process takes under 10 minutes.
      </p>
    </div>

    <div class="wu-steps-row">
      <div class="wu-step text-center sr">
        <div class="wu-step-circle">01</div>
        <h6 class="fw-800 mb-2">Upload your CV</h6>
        <p style="font-size:.85rem;color:var(--ink-3);line-height:1.6">Drop your PDF and we extract your full career story in seconds.</p>
      </div>
      <div class="wu-step-line"></div>
      <div class="wu-step text-center sr d1">
        <div class="wu-step-circle">02</div>
        <h6 class="fw-800 mb-2">Get your analysis</h6>
        <p style="font-size:.85rem;color:var(--ink-3);line-height:1.6">We identify your transferable skills and market positioning.</p>
      </div>
      <div class="wu-step-line"></div>
      <div class="wu-step text-center sr d2">
        <div class="wu-step-circle">03</div>
        <h6 class="fw-800 mb-2">Explore career paths</h6>
        <p style="font-size:.85rem;color:var(--ink-3);line-height:1.6">Choose from 3 curated roles matched to your unique background.</p>
      </div>
      <div class="wu-step-line"></div>
      <div class="wu-step text-center sr d3">
        <div class="wu-step-circle">04</div>
        <h6 class="fw-800 mb-2">Practice with the chat</h6>
        <p style="font-size:.85rem;color:var(--ink-3);line-height:1.6">Run mock interviews and get scored feedback until you're ready.</p>
      </div>
    </div>
  </div>
</section>

<%# ── Features ─────────────────────────────────────────────────────────────── %>
<section class="py-9" style="background:#ede9fe">
  <div class="container" style="max-width:1100px">
    <div class="text-center mb-5">
      <h2 class="fw-800 fs-2">Three tools. One goal: <span class="text-brand">get hired.</span></h2>
    </div>

    <div class="row g-4">
      <div class="col-12 col-md-4 sr">
        <div class="wu-card wu-card-hover h-100">
          <div style="font-size:2rem;margin-bottom:1rem">🧠</div>
          <h5 class="fw-800 mb-2">Smart Analysis</h5>
          <p style="color:var(--ink-3);font-size:.9rem;line-height:1.7">
            Upload your CV and Wagon Up analysis it, extracting transferable skills
            your resume never made explicit.
          </p>
        </div>
      </div>
      <div class="col-12 col-md-4 sr d1">
        <div class="wu-card wu-card-hover h-100">
          <div style="font-size:2rem;margin-bottom:1rem">🎯</div>
          <h5 class="fw-800 mb-2">Role Matching</h5>
          <p style="color:var(--ink-3);font-size:.9rem;line-height:1.7">
            Get 3 tailored career paths ranked by market fit with justification, salary data,
            and a ready-to-use resume prompt.
          </p>
        </div>
      </div>
      <div class="col-12 col-md-4 sr d2">
        <div class="wu-card wu-card-hover h-100">
          <div style="font-size:2rem;margin-bottom:1rem">💬</div>
          <h5 class="fw-800 mb-2">Interview Coach</h5>
          <p style="color:var(--ink-3);font-size:.9rem;line-height:1.7">
            Practice with the chat, get real-time feedback, scores, and
            improvement tips after each answer.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

