<% @interview ||= OpenStruct.new(
  id: 0,
  overall_score: 8,
  feedback_summary: "Strong performance overall.",
  category: "General",
  role: nil,
  answers: []
) %>
<% @role ||= @interview.role %>

<% content_for :title, "Results — #{@role&.title || "Practice"}" %>

<div style="background:var(--bg);min-height:calc(100vh - 68px);padding:2rem 1rem">
  <div style="max-width:680px;margin:0 auto">

    <%= link_to "← Back to interview", interview_path(@interview),
        style: "font-size:.8rem;color:var(--ink-3);text-decoration:none;display:inline-flex;align-items:center;gap:.3rem;margin-bottom:1.25rem" %>

    <%# ── Compact hero ── %>
    <div style="background:#0f0a1e;border-radius:16px;padding:1.5rem 2rem;margin-bottom:1.25rem;display:flex;align-items:center;justify-content:space-between;gap:1.5rem;flex-wrap:wrap">
      <div>
        <div style="font-size:.7rem;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.3rem">Results</div>
        <div style="font-size:1.25rem;font-weight:800;color:#fff;letter-spacing:-.02em;margin-bottom:.25rem">
          <%= @role ? @role.title : "Practice Interview" %>
        </div>
        <% if @interview.overall_score %>
          <% label, color = case @interview.overall_score
             when 8..10 then ["Excellent", "#4ade80"]
             when 6..7  then ["Good", "#a78bfa"]
             when 4..5  then ["Fair", "#fbbf24"]
             else            ["Keep going", "#f87171"]
             end %>
          <span style="font-size:.72rem;font-weight:700;color:<%= color %>"><%= label %></span>
        <% end %>
      </div>
      <div style="text-align:center;flex-shrink:0">
        <div style="font-size:2.5rem;font-weight:800;color:#fff;line-height:1">
          <%= @interview.overall_score || "—" %><span style="font-size:1rem;color:rgba(255,255,255,.4)">/10</span>
        </div>
        <div style="font-size:.65rem;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:.08em;margin-top:3px">Overall</div>
      </div>
    </div>

    <%# ── Summary box ── %>
    <% if @interview.feedback_summary.present? %>
      <% summary = begin; JSON.parse(@interview.feedback_summary); rescue; nil; end %>
      <% if summary.is_a?(Hash) %>
        <div style="background:#fff;border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:1.25rem">
          <% [
               ["⭐", "Strongest moment", summary["strongest_moment"], "#d1fae5", "#065f46"],
               ["⚠️", "Main gap",         summary["main_gap"],         "#fef9c3", "#854d0e"],
               ["→",  "Before your next interview", summary["action"], "#ede8ff", "#5b21b6"]
             ].each_with_index do |(icon, label, text, bg, fg), i| %>
            <% next if text.blank? %>
            <div style="display:flex;gap:.9rem;padding:.9rem 1.25rem;border-bottom:<%= i == 2 ? 'none' : '1px solid var(--border)' %>">
              <span style="font-size:.95rem;flex-shrink:0;margin-top:1px"><%= icon %></span>
              <div>
                <div style="font-size:.68rem;font-weight:700;color:<%= fg %>;text-transform:uppercase;letter-spacing:.08em;background:<%= bg %>;display:inline-block;padding:1px 7px;border-radius:100px;margin-bottom:.35rem"><%= label %></div>
                <p style="font-size:.84rem;color:var(--ink-2);line-height:1.65;margin:0"><%= text %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <%
          raw_text = @interview.feedback_summary.to_s
                       .sub(/\ASESSION COMPLETE\s*/i, "")
                       .sub(/Overall score:\s*\d+\/\d+\s*/i, "")
                       .strip
          sections = []
          if (m = raw_text.match(/Strongest moment:\s*(.+?)(?=\s*#1 gap:|\s*Before your next|\z)/im))
            sections << ["⭐", "Strongest moment", m[1].strip, "#d1fae5", "#065f46"]
          end
          if (m = raw_text.match(/#1 gap:\s*(.+?)(?=\s*Before your next|\z)/im))
            sections << ["⚠️", "Main gap", m[1].strip, "#fef9c3", "#854d0e"]
          end
          if (m = raw_text.match(/Before your next interview[^:]*:\s*(.+)\z/im))
            sections << ["→", "Before your next interview", m[1].strip, "#ede8ff", "#5b21b6"]
          end
        %>
        <% if sections.any? %>
          <div style="background:#fff;border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:1.25rem">
            <% sections.each_with_index do |(icon, label, text, bg, fg), i| %>
              <div style="display:flex;gap:.9rem;padding:1rem 1.25rem;border-bottom:<%= i == sections.size - 1 ? 'none' : '1px solid var(--border)' %>">
                <span style="font-size:.95rem;flex-shrink:0;margin-top:2px"><%= icon %></span>
                <div>
                  <div style="font-size:.68rem;font-weight:700;color:<%= fg %>;text-transform:uppercase;letter-spacing:.08em;background:<%= bg %>;display:inline-block;padding:1px 7px;border-radius:100px;margin-bottom:.4rem"><%= label %></div>
                  <p style="font-size:.84rem;color:var(--ink-2);line-height:1.7;margin:0"><%= text %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div style="background:#fff;border:1px solid var(--border);border-radius:12px;padding:1.1rem 1.25rem;margin-bottom:1.25rem">
            <p style="font-size:.84rem;color:var(--ink-2);line-height:1.7;margin:0"><%= raw_text %></p>
          </div>
        <% end %>
      <% end %>
    <% end %>

    <%# ── Question breakdown ── %>
    <% answers = @interview.answers.to_a %>
    <% if answers.any? %>
      <div style="background:#fff;border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:1.25rem">
        <div style="padding:.85rem 1.25rem;border-bottom:1px solid var(--border)">
          <span style="font-size:.7rem;font-weight:700;color:var(--ink-3);text-transform:uppercase;letter-spacing:.1em">Question Breakdown</span>
        </div>

        <% answers.each_with_index do |ans, i| %>
          <details style="border-bottom:<%= i == answers.size - 1 ? 'none' : '1px solid var(--border)' %>">
            <summary style="padding:.5rem 1.25rem;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:.75rem;list-style:none;user-select:none">
              <div style="display:flex;align-items:center;gap:.6rem;flex:1;min-width:0">
                <span style="font-size:.7rem;font-weight:700;color:var(--ink-3);flex-shrink:0">Q<%= i + 1 %></span>
                <span style="font-size:.82rem;font-weight:500;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                  <%= ans.question.presence || "Question #{i + 1}" %>
                </span>
              </div>
              <% if ans.score %>
                <% bg = ans.score >= 8 ? "#d1fae5" : ans.score >= 6 ? "#ede8ff" : ans.score >= 4 ? "#fef9c3" : "#fee2e2" %>
                <% fg = ans.score >= 8 ? "#065f46" : ans.score >= 6 ? "#5b21b6" : ans.score >= 4 ? "#854d0e" : "#991b1b" %>
                <span style="font-size:.72rem;font-weight:700;padding:2px 9px;border-radius:100px;background:<%= bg %>;color:<%= fg %>;flex-shrink:0"><%= ans.score %>/10</span>
              <% end %>
            </summary>
            <div style="padding:.75rem 1.25rem 1rem;background:#FAFAFA">
              <% if ans.answer.present? %>
                <div style="font-size:.82rem;color:var(--ink-2);background:#fff;border:1px solid var(--border);border-radius:8px;padding:.65rem .9rem;margin-bottom:.75rem;line-height:1.65;margin-top:.25rem">
                  <%= ans.answer %>
                </div>
              <% end %>
              <% if ans.feedback.present? %>
                <%
                  feedback_clean = ans.feedback
                    .gsub(/_([^_]+)_/, '\1')
                    .gsub(/\*\*([^*]+)\*\*/, '\1')
                    .sub(/\n?Score:\s*\d+\/10\s*\z/i, "")
                    .strip
                  lines = feedback_clean.split(/\n+/).map(&:strip).reject(&:blank?)
                %>
                <div style="font-size:.82rem;color:var(--ink-2);line-height:1.7;display:flex;flex-direction:column;gap:.4rem">
                  <% lines.each do |line| %>
                    <p style="margin:0"><%= line %></p>
                  <% end %>
                </div>
              <% end %>
            </div>
          </details>
        <% end %>
      </div>
    <% end %>

    <%# ── Actions ── %>
    <div style="display:flex;gap:.75rem;flex-wrap:wrap">
      <% if @role %>
        <%= form_with url: role_interviews_path(@role), method: :post do |f| %>
          <%= hidden_field_tag "interview[category]", @role.title %>
          <%= f.submit "Practice again →", class: "btn-wu btn-wu-primary" %>
        <% end %>
        <%= link_to "Back to role", role_path(@role), class: "btn-wu btn-wu-outline" %>
      <% end %>
      <%= link_to "My profile", analyses_path, class: "btn-wu btn-wu-outline" %>
    </div>

  </div>
</div>
