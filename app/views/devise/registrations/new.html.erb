<div class="wu-auth-bg">
  <div class="wu-auth-card">
    <%= link_to "Wagon Up", root_path, class: "wu-brand", style: "display:block;text-align:center;font-size:1.5rem;margin-bottom:1rem;text-decoration:none" %>

    <h1 class="wu-auth-title">Create your account</h1>
    <p class="wu-auth-sub">Start your journey to your first tech role </p>

    <% if resource.errors.any? %>
      <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:1rem;margin-bottom:1rem;font-size:.83rem;color:#dc2626">
        <% resource.errors.full_messages.each do |msg| %>
          <div>• <%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "wu-auth-form" }) do |f| %>
      <div class="mb-3">
        <%= f.label :name, "Full Name" %>
        <%= f.text_field :name, placeholder: "Your name", autocomplete: "name", autofocus: true %>
      </div>

      <div class="mb-3">
        <%= f.label :email, "Email address" %>
        <%= f.email_field :email, placeholder: "Your email", autocomplete: "email" %>
      </div>

      <div class="mb-3">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password, placeholder: "••••••••", autocomplete: "new-password" %>
        <% if @minimum_password_length %>
          <small style="font-size:.75rem;color:var(--ink-3);display:block;margin-top:.3rem">
            Minimum <%= @minimum_password_length %> characters
          </small>
        <% end %>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation, "Confirm password" %>
        <%= f.password_field :password_confirmation, placeholder: "••••••••", autocomplete: "new-password" %>
      </div>

      <%= f.submit "Create my account →" %>
    <% end %>

    <div class="wu-auth-switch">
      Already have an account? <%= link_to "Sign in", new_user_session_path %>
    </div>
  </div>
</div>
