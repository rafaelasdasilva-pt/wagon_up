<div class="wu-auth-bg">
  <div class="wu-auth-card">
    <%= link_to "Wagon Up", root_path, class: "wu-brand", style: "display:block;text-align:center;font-size:1.5rem;margin-bottom:1rem;text-decoration:none" %>

    <h1 class="wu-auth-title">Welcome back</h1>
    <p class="wu-auth-sub">Sign in to continue your career journey.</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "wu-auth-form" }) do |f| %>
      <div class="mb-3">
        <%= f.label :email, "Email address" %>
        <%= f.email_field :email, placeholder: "Your email", autocomplete: "email", autofocus: true %>
      </div>

      <div class="mb-3">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password, placeholder: "••••••••", autocomplete: "current-password" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-3 d-flex align-items-center gap-2">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, style: "font-size:.82rem;font-weight:500;margin-bottom:0;cursor:pointer" %>
        </div>
      <% end %>

      <%= f.submit "Sign in →" %>
    <% end %>

    <div class="wu-auth-switch">
      New here? <%= link_to "Create an account", new_user_registration_path %>
    </div>

    <% if devise_mapping.recoverable? %>
      <div style="text-align:center;margin-top:.75rem">
        <%= link_to "Forgot your password?", new_user_password_path, style: "font-size:.78rem;color:var(--ink-3);text-decoration:none" %>
      </div>
    <% end %>
  </div>
</div>
